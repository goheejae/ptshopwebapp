# ══════════════════════════════════════════════════════════
# 핏플랜PT 웹앱 — 환경변수 설정 템플릿
#
# 사용법:
#   1. 이 파일을 복사해 .env 로 저장 (로컬 개발 시)
#   2. Netlify 대시보드 → Site configuration → Environment variables 에
#      아래 키를 등록 (프로덕션 배포 시)
#
# ⚠️  .env 파일은 절대 git에 커밋하지 마세요 (.gitignore 확인)
# ══════════════════════════════════════════════════════════

# ── Claude (Anthropic) API ──────────────────────────────
# https://console.anthropic.com → API Keys 에서 발급
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── 네이버 Open API ─────────────────────────────────────
# https://developers.naver.com → 애플리케이션 등록 후 발급
# 필요 API: DataLab (검색어 트렌드)
NAVER_CLIENT_ID=xxxxxxxxxxxxxxxxxxxx
NAVER_CLIENT_SECRET=xxxxxxxxxx
